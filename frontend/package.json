{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Portfolio landing page with astrophotography gallery, built with React, TypeScript, and Vite. Features TanStack Query, PWA support, advanced caching, and SEO optimization.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run type-check && npm run lint && npm run format:check && npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@sentry/react": "^10.38.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "axios": "^1.13.6",
    "dompurify": "^3.3.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "0.563.0",
    "qs": "^6.15.0",
    "react": "^18.0.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.22.3",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@babel/preset-typescript": "^7.0.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/babel__template": "^7.4.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.33",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "babel-plugin-istanbul": "^7.0.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.2.0",
    "identity-obj-proxy": "^3.0.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "test-exclude": "^7.0.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.4.1",
    "vite-plugin-pwa": "^0.21.2"
  },
  "overrides": {
    "glob": "^11.0.0",
    "test-exclude": "^7.0.1",
    "istanbul-lib-instrument": "^6.0.3",
    "qs": "^6.15.0",
    "minimatch": "^10.2.1"
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead"
  ]
}
